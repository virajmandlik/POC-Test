# F4F POC Environment Configuration
# Copy to .env and fill in values:  cp .env.example .env

# ── API Keys ─────────────────────────────────────────────────────
CXAI_API_KEY=

# ── MongoDB ──────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017
MONGO_DB=f4f_poc

# ── Job Engine ───────────────────────────────────────────────────
JOB_WORKER_THREADS=2

# ── API Server ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
